APP_NAME="Gestion Laboratoire"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Africa/Douala
APP_URL=http://localhost:8000
APP_LOCALE=fr

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# --- Base de données ---
# Par défaut : SQLite (aucune installation MySQL requise, idéal pour démarrer vite)
DB_CONNECTION=sqlite
# DB_DATABASE=/chemin/absolu/vers/database/database.sqlite

# Pour utiliser MySQL, décommentez et adaptez ces lignes puis mettez DB_CONNECTION=mysql
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=gestion_labo
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=180
SESSION_ENCRYPT=false

CACHE_STORE=file
QUEUE_CONNECTION=sync

MAIL_MAILER=log
